# ============================================================================
# Mnemo Environment Variables
# Copy this to .env and fill in your values
# ============================================================================

# --- LLM Provider (for entity extraction & digest generation) ---
# Provider: anthropic (recommended), openai, ollama, liquid
MNEMO_LLM_PROVIDER=anthropic
MNEMO_LLM_MODEL=claude-sonnet-4-20250514
MNEMO_LLM_API_KEY=
# MNEMO_LLM_BASE_URL=              # Override for Ollama/Liquid/custom endpoints

# --- Embedding Provider ---
# Provider: openai (remote), local (fastembed, no API key needed)
MNEMO_EMBEDDING_PROVIDER=openai
MNEMO_EMBEDDING_MODEL=text-embedding-3-small
MNEMO_EMBEDDING_DIMENSIONS=1536
MNEMO_EMBEDDING_API_KEY=
# MNEMO_EMBEDDING_BASE_URL=        # Override for custom embedding endpoints
# For local embeddings (no API key required):
# MNEMO_EMBEDDING_PROVIDER=local
# MNEMO_EMBEDDING_MODEL=AllMiniLML6V2
# MNEMO_EMBEDDING_DIMENSIONS=384

# --- Infrastructure ---
MNEMO_REDIS_URL=redis://localhost:6379
MNEMO_QDRANT_URL=http://localhost:6334
# MNEMO_QDRANT_PREFIX=mnemo_       # Collection prefix (useful for multi-tenant or migrations)

# --- Server ---
# MNEMO_SERVER_HOST=0.0.0.0
# MNEMO_SERVER_PORT=8080
# MNEMO_CONFIG=config/default.toml # Path to custom TOML config file

# --- Authentication ---
# MNEMO_AUTH_ENABLED=true
# MNEMO_AUTH_API_KEYS=key1,key2    # Comma-separated accepted API keys

# --- Webhooks ---
# MNEMO_WEBHOOKS_ENABLED=true
# MNEMO_REQUIRE_TLS=false          # Reject non-HTTPS webhook targets when true

# --- Sleep-time Compute ---
# MNEMO_SLEEP_ENABLED=true                 # Background digest generation & re-ranking
# MNEMO_SLEEP_IDLE_WINDOW_SECONDS=300      # Inactivity threshold before background tasks

# --- Compliance ---
# MNEMO_AUDIT_SIGNING_SECRET=              # HMAC secret for signing audit exports (SOC 2)
