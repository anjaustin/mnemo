# ============================================================================
# Mnemo Environment Variables
# Copy this to .env and fill in your values
# ============================================================================

# LLM provider API key (for entity extraction)
# Supports: Anthropic, OpenAI, or leave empty to use local/Ollama
MNEMO_LLM_API_KEY=

# Embedding provider API key
MNEMO_EMBEDDING_API_KEY=

# Optional: Override LLM provider (default: openai)
# Options: anthropic, openai, ollama, liquid
# MNEMO_LLM_PROVIDER=anthropic
# MNEMO_LLM_MODEL=claude-sonnet-4-20250514

# Optional: Override connection URLs
# MNEMO_REDIS_URL=redis://localhost:6379
# MNEMO_QDRANT_URL=http://localhost:6334

# Optional: Server configuration
# MNEMO_SERVER_HOST=0.0.0.0
# MNEMO_SERVER_PORT=8080
