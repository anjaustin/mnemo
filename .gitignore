# Rust
/target
**/*.rs.bk
Cargo.lock

# Environment
.env
*.key

# Credentials / cloud keys — never commit
.keys/
*.pem
credentials.json

# Terraform state (defense-in-depth — also covered by subdirectory .gitignore)
terraform.tfstate
terraform.tfstate.backup

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Docker volumes
redis-data/
qdrant-data/
