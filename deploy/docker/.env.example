# ============================================================================
# Mnemo Production Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================================

# ----------------------------------------------------------------------------
# Image version (default: latest)
# Pin to a specific version for reproducible deployments, e.g. 0.3.1
# ----------------------------------------------------------------------------
MNEMO_VERSION=latest

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
MNEMO_SERVER_PORT=8080

# ----------------------------------------------------------------------------
# Storage — self-hosted (docker-compose.prod.yml)
# These point to service names inside the compose network.
# Do not change unless you know what you are doing.
# ----------------------------------------------------------------------------
# MNEMO_REDIS_URL=redis://redis:6379
# MNEMO_QDRANT_URL=http://qdrant:6334

# ----------------------------------------------------------------------------
# Storage — managed services (docker-compose.managed.yml)
# Uncomment and set when using external Redis and Qdrant.
# Redis: must support RedisSearch and RedisJSON modules (Redis Stack).
#   - Upstash: https://upstash.com  (Redis Stack on free tier)
#   - Redis Cloud: https://redis.io/cloud
#   - AWS ElastiCache: use a Redis 7 cluster with modules enabled
# Qdrant: https://cloud.qdrant.io  (free 1 GB cluster)
# ----------------------------------------------------------------------------
# MNEMO_REDIS_URL=redis://:password@your-redis-host:6379
# MNEMO_QDRANT_URL=https://your-cluster.cloud.qdrant.io:6334

# Optional: Redis password (for docker-compose.prod.yml internal Redis)
# REDIS_PASSWORD=changeme

# ----------------------------------------------------------------------------
# LLM — optional; Mnemo works without an LLM (no enrichment/summarization)
# ----------------------------------------------------------------------------
MNEMO_LLM_PROVIDER=openai           # openai | anthropic | ollama | liquid
MNEMO_LLM_API_KEY=
MNEMO_LLM_MODEL=gpt-4o-mini

MNEMO_EMBEDDING_API_KEY=
MNEMO_EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------------------------------------------------------
# Auth — DISABLED by default. Enable before exposing Mnemo publicly.
# ----------------------------------------------------------------------------
MNEMO_AUTH_ENABLED=false
MNEMO_AUTH_API_KEYS=                # comma-separated API keys, e.g. key1,key2

# ----------------------------------------------------------------------------
# Webhooks
# ----------------------------------------------------------------------------
MNEMO_WEBHOOKS_ENABLED=true
MNEMO_WEBHOOKS_MAX_ATTEMPTS=3

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
RUST_LOG=mnemo=info
